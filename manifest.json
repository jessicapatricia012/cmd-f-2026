{
  "manifest_version": 3,
  "name": "AFK",
  "version": "0.1.0",
  "description": "Hands-free browser control via hand gesture recognition and voice commands.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "sandbox": {
    "pages": [
      "offscreen/face-mesh-sandbox.html",
      "offscreen/hands-sandbox.html"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content/*",
        "assets/icons/*",
        "assets/mediapipe/*",
        "node_modules/@mediapipe/face_mesh/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}